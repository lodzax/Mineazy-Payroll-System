rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVE HELPERS ---
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getSubsidiaryId() {
      return getUserData().subsidiaryId;
    }

    function isAdmin() { 
      // check for bootstrapped admin emails first
      let isOfficial = isSignedIn() && (
        request.auth.token.email == 'lodzax@gmail.com' || 
        request.auth.token.email == 'accounts@mineazy.co.zw'
      );
      return isOfficial || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin'); 
    }

    function isSuperAdmin() {
      return isSignedIn() && (request.auth.token.email == 'lodzax@gmail.com' || request.auth.token.email == 'accounts@mineazy.co.zw');
    }

    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }

    // Returns true if the user is a super admin, OR if the data belongs to the same subsidiary
    function isSameSubsidiary(data) {
      return isSuperAdmin() || (data.subsidiaryId == getSubsidiaryId());
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // --- VALIDATION BLUEPRINTS ---
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 100
        && data.fullName is string && data.fullName.size() <= 100
        && data.role in ['employee', 'admin']
        && (!('subsidiaryId' in data) || data.subsidiaryId is string)
    }

    function isValidSubsidiary(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.status in ['active', 'suspended'];
    }

    function isValidTimesheet(data) {
      return data.employeeId == request.auth.uid
        && data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && data.month is string && data.month.matches('^\\d{4}-\\d{2}$')
        && data.submissionMode in ['daily', 'weekly', 'monthly']
        && data.hoursWorked is number && data.hoursWorked >= 0 && data.hoursWorked <= 1000
        && data.overtimeHours is number && data.overtimeHours >= 0
        && data.description is string && data.description.size() <= 1000
        && data.status == 'pending'
        && data.submittedAt == request.time
        && (!('subsidiaryId' in data) || data.subsidiaryId is string);
    }

    function isValidReview(data) {
      return data.employeeId is string 
        && data.reviewerId == request.auth.uid
        && data.reviewDate is string
        && data.overallRating is number && data.overallRating >= 1 && data.overallRating <= 5
        && data.status in ['scheduled', 'conducted', 'completed']
        && (!('feedback' in data) || data.feedback is string)
        && (!('goals' in data) || data.goals is string)
        && data.createdAt == request.time;
    }

    function isBatchFinalized(month, subId) {
      let specificId = subId + '-' + month;
      let globalId = 'all-' + month;
      return (exists(/databases/$(database)/documents/payroll_batches/$(specificId)) && 
              get(/databases/$(database)/documents/payroll_batches/$(specificId)).data.status == 'finalized') ||
             (exists(/databases/$(database)/documents/payroll_batches/$(globalId)) && 
              get(/databases/$(database)/documents/payroll_batches/$(globalId)).data.status == 'finalized');
    }

    function isValidPii(data) {
      return (data.keys().hasAll(['updatedAt', 'updatedBy'])) 
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 50))
        && (!('address' in data) || (data.address is string && data.address.size() <= 500))
        && (!('emergencyContact' in data) || (data.emergencyContact is string && data.emergencyContact.size() <= 100))
        && (!('emergencyRelation' in data) || (data.emergencyRelation is string && data.emergencyRelation.size() <= 50))
        && (!('emergencyPhone' in data) || (data.emergencyPhone is string && data.emergencyPhone.size() <= 50))
        && (!('nationalId' in data) || (data.nationalId is string && data.nationalId.size() <= 100))
        && (!('medicalAidNo' in data) || (data.medicalAidNo is string && data.medicalAidNo.size() <= 100))
        && (!('bankName' in data) || (data.bankName is string && data.bankName.size() <= 100))
        && (!('accountNumber' in data) || (data.accountNumber is string && data.accountNumber.size() <= 100))
        && (!('branchCode' in data) || (data.branchCode is string && data.branchCode.size() <= 50))
        && (!('accountName' in data) || (data.accountName is string && data.accountName.size() <= 100))
        && data.updatedAt == request.time;
    }

    function isValidAuditLog(data) {
      return data.userId == request.auth.uid
        && data.action is string && data.action.size() <= 200
        && data.category in ["payroll", "personnel", "system", "financial", "performance", "report"]
        && data.timestamp == request.time
        && (!('details' in data) || (data.details is string && data.details.size() <= 2000))
        && (!('userName' in data) || (data.userName is string && data.userName.size() <= 100))
        && (!('userEmail' in data) || (data.userEmail is string && data.userEmail.size() <= 100))
        && (!('entityId' in data) || (data.entityId is string && data.entityId.size() <= 128));
    }

    // --- COLLECTIONS ---

    match /audit_logs/{logId} {
      allow list, get: if isAdmin();
      allow create: if isSignedIn(); // Simplified for now to ensure logging works
    }

    match /payroll_batches/{batchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isSameSubsidiary(incoming());
    }

    match /subsidiaries/{subId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (isSuperAdmin() || isOwner(userId) || (isAdmin() && isSameSubsidiary(existing())));
      allow create: if (isSuperAdmin() || (isOwner(userId) && isValidUser(incoming()) && incoming().role == 'employee'));
      allow update: if (isSuperAdmin() || (isAdmin() && isSameSubsidiary(existing())) || isOwner(userId)) 
        && (isSuperAdmin() || (incoming().role == existing().role && incoming().uid == existing().uid));

      match /private/details {
        allow read: if isSuperAdmin() || (isAdmin() && isSameSubsidiary(get(/databases/$(database)/documents/users/$(userId)).data)) || isOwner(userId);
        allow write: if (isSuperAdmin() || (isAdmin() && isSameSubsidiary(get(/databases/$(database)/documents/users/$(userId)).data))) && isValidPii(incoming());
      }
      
      match /reviews/{reviewId} {
        allow read: if isSuperAdmin() || isOwner(userId) || (isAdmin() && isSameSubsidiary(get(/databases/$(database)/documents/users/$(userId)).data));
        allow write: if (isSuperAdmin() || (isAdmin() && isSameSubsidiary(get(/databases/$(database)/documents/users/$(userId)).data))) && isValidReview(incoming()) && isValidId(reviewId);
      }
    }

    match /timesheets/{timesheetId} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.employeeId == request.auth.uid || (isAdmin() && isSameSubsidiary(resource.data)));
      allow get: if isSignedIn() && (isSuperAdmin() || resource.data.employeeId == request.auth.uid || (isAdmin() && isSameSubsidiary(resource.data))) && isValidId(timesheetId);
      allow create: if isSignedIn() && isValidTimesheet(incoming()) && isValidId(timesheetId);
      allow update: if (isSuperAdmin() || (isAdmin() && isSameSubsidiary(existing())) || (isOwner(existing().employeeId) && existing().status == 'pending'))
        && (isAdmin() || (incoming().diff(existing()).affectedKeys().hasOnly(['hoursWorked', 'overtimeHours', 'month', 'date', 'description', 'submissionMode'])));
      allow delete: if isAdmin() && isSameSubsidiary(existing());
    }

    match /leave_applications/{applicationId} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.employeeId == request.auth.uid || (isAdmin() && isSameSubsidiary(resource.data)));
      allow get: if isSignedIn() && (isSuperAdmin() || resource.data.employeeId == request.auth.uid || (isAdmin() && isSameSubsidiary(resource.data))) && isValidId(applicationId);
      allow create: if isSignedIn() && incoming().employeeId == request.auth.uid && incoming().status == 'pending' && isValidId(applicationId);
      allow update: if isAdmin() && isSameSubsidiary(existing());
      allow delete: if isAdmin() && isSameSubsidiary(existing());
    }

    match /loan_applications/{loanId} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.employeeId == request.auth.uid || (isAdmin() && isSameSubsidiary(resource.data)));
      allow get: if isSignedIn() && (isSuperAdmin() || resource.data.employeeId == request.auth.uid || (isAdmin() && isSameSubsidiary(resource.data))) && isValidId(loanId);
      allow create: if isSignedIn() && incoming().employeeId == request.auth.uid && incoming().status == 'pending' && isValidId(loanId);
      allow update: if isAdmin() && isSameSubsidiary(existing());
      allow delete: if isAdmin() && isSameSubsidiary(existing());
    }

    match /payslips/{payslipId} {
      allow list: if isSignedIn() && (isSuperAdmin() || resource.data.employeeId == request.auth.uid || (isAdmin() && isSameSubsidiary(resource.data)));
      allow get: if isSignedIn() && (isSuperAdmin() || resource.data.employeeId == request.auth.uid || (isAdmin() && isSameSubsidiary(resource.data))) && isValidId(payslipId);
      allow create: if isAdmin() && isSameSubsidiary(incoming()) && !isBatchFinalized(incoming().month, incoming().subsidiaryId);
      allow update: if isAdmin() && isSameSubsidiary(incoming()) && 
        (!isBatchFinalized(existing().month, existing().subsidiaryId) || 
         (existing().isPublished == false && incoming().isPublished == true));
      allow delete: if isAdmin() && isSameSubsidiary(existing()) && !isBatchFinalized(existing().month, existing().subsidiaryId);
    }
  }
}
